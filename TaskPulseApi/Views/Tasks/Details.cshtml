@model TaskPulse.Application.DTOs.TaskResponseDto

@{
    ViewData["Title"] = "Task Details";
}

<style>
    /* Styling for our beautiful task details card */
    .details-container {
        background-color: #1e1e1e;
        border-radius: 8px;
        padding: 30px;
        margin-top: 20px;
        box-shadow: 0 8px 16px rgba(0,0,0,0.3);
        border-top: 5px solid #03dac6;
    }
    .task-title {
        font-size: 28px;
        color: #ffffff;
        margin-bottom: 10px;
    }
    .task-desc {
        font-size: 16px;
        color: #b3b3b3;
        margin-bottom: 20px;
        line-height: 1.6;
    }
    .status-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: bold;
        margin-bottom: 20px;
    }
    .completed {
        background-color: #03dac6;
        color: #000000;
    }
    .pending {
        background-color: #cf6679;
        color: #ffffff;
    }
    .meta-data {
        font-size: 12px;
        color: #777777;
        margin-bottom: 30px;
    }
    .btn-back {
        background-color: #bb86fc;
        color: #000000;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 5px;
        font-weight: bold;
        display: inline-block;
        transition: background-color 0.2s;
    }
    .btn-back:hover {
        background-color: #9965f4;
    }
</style>

<h2>Task Details</h2>

<div class="details-container">
    @if (Model.IsCompleted)
    {
        <span class="status-badge completed">Status: Completed</span>
    }
    else
    {
        <span class="status-badge pending">Status: Pending</span>
    }

    <h1 class="task-title">@Model.Title</h1>
    <p class="task-desc">
        @(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description)
    </p>

    <div class="meta-data">
        <p><strong>Created on:</strong> @Model.CreatedAt.ToString("f")</p>
        <p><strong>Task ID:</strong> @Model.Id</p>
    </div>

    <!-- The back button simply acts like clicking the back arrow in your browser -->
    <a href="/Tasks" class="btn-back">⬅ Back to Tasks</a>
</div>
